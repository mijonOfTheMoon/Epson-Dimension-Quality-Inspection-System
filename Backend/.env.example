NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info
CORS_ORIGIN=*
STORAGE_DRIVER=json
DATA_FILE=./data/diminspect.json
MQTT_ENABLED=false
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=diminspect-backend
MQTT_TOPIC_PREFIX=diminspect
MQTT_QOS=1
EVENT_REPLAY_LIMIT=100
