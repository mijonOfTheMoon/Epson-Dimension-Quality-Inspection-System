NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info
CORS_ORIGIN=*
STORAGE_DRIVER=postgres
DATABASE_URL=postgresql://diminspect:diminspect@localhost:5432/diminspect
DATABASE_SSL=false
DATABASE_POOL_MAX=10
MQTT_ENABLED=false
MQTT_URL=mqtt://localhost:1883
